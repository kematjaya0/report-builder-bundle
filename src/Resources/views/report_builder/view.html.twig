{% extends '@ReportBuilder/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Report Header -->
    <div class="report-header">
        <div class="d-flex align-items-start gap-3">
            <div class="report-icon">
                <i class="{{ report_query.icon }}"></i>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <h3 class="mb-0 fw-bold" style="color: #FFF">{{ report_query.name }}</h3>
                    {% if report_query.isEnabled %}
                        <span class="badge bg-success">Active</span>
                    {% else %}
                        <span class="badge bg-secondary">Inactive</span>
                    {% endif %}
                </div>
                {% if report_query.description %}
                    <p class="report-meta mb-2">{{ report_query.description }}</p>
                {% endif %}
                <div class="d-flex gap-2 flex-wrap">
                    <span class="stat-pill">
                        <i class="fa fa-clock-o"></i>
                        Created {{ report_query.createdAt ? report_query.createdAt|date('d M Y') : '-' }}
                    </span>
                    <span class="stat-pill">
                        <i class="fa fa-bar-chart"></i>
                        {% if report_query.outputType == 'table' %}Table
                        {% elseif report_query.outputType == 'bar' %}Bar Chart
                        {% elseif report_query.outputType == 'line' %}Line Chart
                        {% elseif report_query.outputType == 'pie' %}Pie Chart
                        {% elseif report_query.outputType == 'scatter' %}Scatter Chart
                        {% endif %}
                    </span>
                    {% if result and result.success %}
                        <span class="stat-pill">
                            <i class="fa fa-table"></i>
                            {{ result.total }} entries found
                        </span>
                    {% endif %}
                </div>
            </div>
            {%if is_granted('ROLE_ADMINISTRATOR')%}
            <div class="d-flex gap-2 ms-auto">
                <a href="{{ path('report_builder_index') }}" class="btn btn-sm btn-primary">
                    <i class="fa fa-arrow-left me-1"></i> Back
                </a>
                <a href="{{ path('report_builder_edit', {id: report_query.id}) }}" class="btn btn-sm btn-warning">
                    <i class="fa fa-pencil me-1"></i> Edit Query
                </a>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Parameter Form -->
    {% if report_query.queryParams %}
    <div class="param-card">
        <h6 class="fw-bold mb-3"><i class="fa fa-filter me-2 text-primary"></i>Report Parameters</h6>
        <form method="post" action="">
            <div class="row g-3 align-items-end">
                {% for param in report_query.queryParams %}
                <div class="col-md-3">
                    <label for="param_{{ param.name }}">{{ param.label ?? param.name }}</label>
                    {% if param.type == 'integer' %}
                        <input type="number" name="{{ param.name }}" id="param_{{ param.name }}"
                               class="form-control form-control-sm"
                               value="{{ app.request.get(param.name, param.default ?? '') }}">
                    {% elseif param.type == 'date' %}
                        <input type="date" name="{{ param.name }}" id="param_{{ param.name }}"
                               class="form-control form-control-sm"
                               value="{{ app.request.get(param.name, param.default ?? '') }}">
                    {% else %}
                        <input type="text" name="{{ param.name }}" id="param_{{ param.name }}"
                               class="form-control form-control-sm"
                               value="{{ app.request.get(param.name, param.default ?? '') }}">
                    {% endif %}
                </div>
                {% endfor %}
                <div class="col-md-2">
                    <button type="submit" class="btn btn-run-report btn-sm w-100">
                        <i class="fa fa-play me-1"></i> Show
                    </button>
                </div>
            </div>
        </form>
    </div>
    {% endif %}

    <!-- Result Area -->
    {% if result %}
        {% if result.success %}
        <div class="card border-0 shadow-sm" style="border-radius:6px; overflow:hidden">
            <!-- Tab Navigation -->
            <ul class="nav report-tabs ps-2 pt-2 pb-0 border-bottom" id="resultTab">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabTable">
                        <i class="fa fa-table me-1"></i> Table
                    </button>
                </li>
                {% if report_query.outputType != 'table' %}
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabChart">
                        <i class="fa fa-bar-chart me-1"></i> Chart
                    </button>
                </li>
                {% endif %}
            </ul>

            <div class="tab-content">
                <!-- Tab Tabel -->
                <div class="tab-pane fade show active" id="tabTable">
                    <div class="toolbar-row">
                        <div class="d-flex align-items-center gap-3">
                            <input type="text" id="tableSearch" class="result-search" placeholder="🔍 Search data...">
                            <span class="badge bg-primary">{{ result.total }} rows</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary" onclick="window.open('{{ path('report_builder_export_csv', {slug: report_query.slug}) }}' + '?' + new URLSearchParams(new FormData(document.querySelector('.param-card form'))).toString())">
                                <i class="fa fa-file-excel-o me-1"></i> Backend CSV
                            </button>
                            <button class="btn btn-sm btn-outline-success" onclick="exportCSV()">
                                <i class="fa fa-download me-1"></i> Client CSV
                            </button>
                        </div>
                    </div>
                    <div class="table-wrapper">
                        <table class="table result-table mb-0" id="resultTable">
                            <thead>
                                <tr>
                                    {% if result.columns %}
                                        {% for col in result.columns %}
                                            <th onclick="sortTable({{ loop.index0 }})" style="cursor:pointer" title="Click to sort">
                                                {{ col|trans }} <i class="fa fa-sort ms-1" style="opacity:0.5;font-size:11px"></i>
                                            </th>
                                        {% endfor %}
                                    {% endif %}
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                {% for row in result.data %}
                                    <tr>
                                        {% for col in result.columns %}
                                            <td>{{ row[col] ?? '' }}</td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Tab Chart -->
                {% if report_query.outputType != 'table' and echarts_option is not null %}
                <div class="tab-pane fade" id="tabChart">
                    <div class="p-3">
                        <div class="chart-controls" id="chartControls">
                            {% for typeOpt in ['bar', 'line', 'pie', 'scatter'] %}
                                <button class="chart-type-btn {{ report_query.outputType == typeOpt ? 'active' : '' }}"
                                        onclick="changeChartType('{{ typeOpt }}', this)">
                                    {% if typeOpt == 'bar' %}📊 Bar
                                    {% elseif typeOpt == 'line' %}📈 Line
                                    {% elseif typeOpt == 'pie' %}🥧 Pie
                                    {% elseif typeOpt == 'scatter' %}💠 Scatter
                                    {% endif %}
                                </button>
                            {% endfor %}
                        </div>
                        <div id="echart-container"></div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        {% else %}
        <!-- Error State -->
        <div class="alert alert-danger border-0 rounded-3 shadow-sm">
            <i class="fa fa-exclamation-triangle me-2"></i>
            <strong>Failed to run query:</strong> {{ result.message }}
        </div>
        {% endif %}

    {% else %}
    <!-- Empty State: Ada parameter yang belum diisi -->
    <div class="empty-result card border-0 shadow-sm" style="border-radius:16px">
        <i class="fa fa-play-circle-o"></i>
        <h5 class="text-muted">Fill parameters and click Show</h5>
        <p class="text-muted small">Complete the parameters above to display report data.</p>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{{ render_chart_js() }}
<script>
// ===== ECharts =====
{% if echarts_option is not null and echarts_option is not empty %}
const echartsOption = {{ echarts_option|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};
let chart = null;

document.querySelector('[data-bs-target="#tabChart"]')?.addEventListener('shown.bs.tab', function() {
    if (!chart) {
        chart = echarts.init(document.getElementById('echart-container'));
        chart.setOption(echartsOption);
    }
    chart.resize();
});

window.addEventListener('resize', () => { if (chart) chart.resize(); });

function changeChartType(type, btn) {
    document.querySelectorAll('.chart-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (!chart) return;

    const currentXData = echartsOption.xAxis ? echartsOption.xAxis.data : [];
    const currentYData = echartsOption.series[0].data;
    const currentName = echartsOption.series[0].name;

    let newOption = {};
    if (type === 'pie') {
        newOption = {
            xAxis: { show: false },
            yAxis: { show: false },
            series: [{
                type: 'pie',
                radius: ['40%', '70%'],
                data: currentXData.map((x, i) => ({ name: x, value: currentYData[i] })),
                name: currentName
            }]
        };
    } else {
        newOption = {
            xAxis: { show: true, type: 'category', data: currentXData, axisLabel: { rotate: 30 } },
            yAxis: { show: true, type: 'value' },
            series: [{
                type: type,
                data: currentYData,
                name: currentName,
                smooth: type === 'line'
            }]
        };
    }
    chart.setOption(newOption, true);
}

{% endif %}

// ===== Table Search =====
document.getElementById('tableSearch')?.addEventListener('input', function() {
    const kw = this.value.toLowerCase();
    document.querySelectorAll('#tableBody tr').forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(kw) ? '' : 'none';
    });
});

// ===== Sort Table =====
let sortDir = {};
function sortTable(colIndex) {
    const tbody = document.getElementById('tableBody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    sortDir[colIndex] = !sortDir[colIndex];
    rows.sort((a, b) => {
        const av = a.cells[colIndex]?.textContent.trim() || '';
        const bv = b.cells[colIndex]?.textContent.trim() || '';
        const n = parseFloat(av) - parseFloat(bv);
        if (!isNaN(n)) return sortDir[colIndex] ? n : -n;
        return sortDir[colIndex] ? av.localeCompare(bv) : bv.localeCompare(av);
    });
    rows.forEach(r => tbody.appendChild(r));
}

// ===== Export CSV =====
function exportCSV() {
    const table = document.getElementById('resultTable');
    const rows = Array.from(table.querySelectorAll('tr'));
    const csv = rows.filter(r => r.style.display !== 'none').map(r =>
        Array.from(r.cells).map(c => '"' + c.textContent.trim().replace(/"/g,'""') + '"').join(',')
    ).join('\n');

    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = '{{ report_query.slug }}_{{ "now"|date("Ymd") }}.csv';
    a.click(); URL.revokeObjectURL(url);
}
</script>
{% endblock %}
